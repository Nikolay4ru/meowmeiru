#!/bin/sh
# mierukop CLI — manage the mieru policy-routing module
CONF="mierukop"
NFT_TABLE="inet mierukop"
NFT_SET="mierukop_subnets"
SOCKS_PORT="$(uci -q get $CONF.settings.socks_port || echo 1180)"

usage() {
	cat <<EOF
mierukop — policy routing over mieru (podkop-style)

Usage: mierukop <command>
  start | stop | restart     manage the service
  status                     show service + tunnel health
  test                       check tunnel exit IP + a proxied domain
  update                     re-download all lists (via the tunnel) + apply
  lists                      show available community lists
  list add <name>            enable a community list (then: mierukop update)
  list del <name>            disable a community list
  list show                  show enabled community lists
  set-server <ip> <port> <user> <pass>   configure mieru endpoint
  add-domain <domain>        route a single domain through the tunnel
  add-subnet <cidr>          route a subnet through the tunnel
  count                      how many subnets are loaded
EOF
}

case "$1" in
	start|stop|restart) /etc/init.d/mierukop "$1" ;;
	status)
		echo "service: $(/etc/init.d/mierukop running >/dev/null 2>&1 && echo running || echo stopped)"
		echo "mieru:   $(pgrep -f '/usr/bin/mieru' >/dev/null && echo up || echo down)"
		echo "tun2socks: $(pgrep -f hev-socks5-tunnel >/dev/null && echo up || echo down)"
		echo "tun dev: $(ip -br addr show $(uci -q get $CONF.settings.tun_name) 2>/dev/null || echo absent)"
		echo "subnets: $(nft list set $NFT_TABLE $NFT_SET 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' | wc -l)"
		;;
	test)
		echo -n "tunnel exit IP: "
		curl -fs --max-time 12 --proxy "socks5h://127.0.0.1:${SOCKS_PORT}" https://api.ipify.org 2>/dev/null || echo "FAIL"
		echo
		echo -n "telegram via tunnel: "
		curl -fs --max-time 12 --proxy "socks5h://127.0.0.1:${SOCKS_PORT}" -o /dev/null -w "HTTP %{http_code}\n" https://core.telegram.org/ 2>/dev/null || echo "FAIL"
		;;
	update) echo "downloading lists via tunnel…"; /etc/mierukop/update-lists.sh download; echo "done. $(/usr/bin/mierukop count) subnets in set" ;;
	lists)  echo "available:"; /etc/mierukop/update-lists.sh available | tr " " "\n" | sed "/^$/d;s/^/  /" ;;
	list)
		case "$2" in
			show) echo "enabled: $(uci -q get $CONF.settings.community_lists)" ;;
			add)
				[ -n "$3" ] || { echo "usage: mierukop list add <name>"; exit 1; }
				cur=" $(uci -q get $CONF.settings.community_lists) "
				case "$cur" in *" $3 "*) echo "$3 already enabled"; exit 0;; esac
				uci set $CONF.settings.community_lists="$(echo $cur $3)"; uci commit $CONF
				echo "enabled $3; run: mierukop update" ;;
			del)
				[ -n "$3" ] || { echo "usage: mierukop list del <name>"; exit 1; }
				new=$(uci -q get $CONF.settings.community_lists | tr " " "\n" | grep -vx "$3" | tr "\n" " ")
				uci set $CONF.settings.community_lists="$new"; uci commit $CONF
				echo "disabled $3; run: mierukop restart" ;;
			*) echo "usage: mierukop list [show|add <name>|del <name>]" ;;
		esac ;;
	count) nft list set $NFT_TABLE $NFT_SET 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/[0-9]+' | wc -l ;;
	set-server)
		[ $# -eq 5 ] || { echo "usage: mierukop set-server <ip> <port> <user> <pass>"; exit 1; }
		uci set $CONF.settings.server="$2"
		uci set $CONF.settings.port="$3"
		uci set $CONF.settings.username="$4"
		uci set $CONF.settings.password="$5"
		uci commit $CONF
		echo "saved; run: mierukop restart"
		;;
	add-domain)
		[ -n "$2" ] || { echo "usage: mierukop add-domain <domain>"; exit 1; }
		uci add_list $CONF.user.domain="$2"; uci commit $CONF
		echo "added domain $2; run: mierukop restart"
		;;
	add-subnet)
		[ -n "$2" ] || { echo "usage: mierukop add-subnet <cidr>"; exit 1; }
		uci add_list $CONF.user.subnet="$2"; uci commit $CONF
		nft add element $NFT_TABLE $NFT_SET "{ $2 }" 2>/dev/null
		echo "added subnet $2"
		;;
	*) usage ;;
esac
