#!/bin/sh
# mierukop CLI — manage the mieru policy-routing module
CONF="mierukop"
NFT_TABLE="inet mierukop"
NFT_SET="mierukop_subnets"
SOCKS_PORT="$(uci -q get $CONF.settings.socks_port || echo 1180)"
PROXY="socks5h://127.0.0.1:${SOCKS_PORT}"
TUN="$(uci -q get $CONF.settings.tun_name || echo mtun0)"
STATE_DIR="/tmp/mierukop"; mkdir -p "$STATE_DIR" 2>/dev/null
TRAFFIC_LOG="$STATE_DIR/traffic.csv"
VER_FILE="/etc/mierukop/VERSION"
VERSION="$(cat "$VER_FILE" 2>/dev/null || echo 0.0.0)"
REPO_RAW="${MIERUKOP_REPO:-https://raw.githubusercontent.com/Nikolay4ru/meowmeiru/main}"
# fetch a repo file: try via the tunnel first (raw.githubusercontent is DPI-blocked
# in RU), then direct as a fallback.
repo_dl() { curl -fs --proxy "$PROXY" --max-time 60 -o "$2" "$REPO_RAW/$1" 2>/dev/null || curl -fs --max-time 60 -o "$2" "$REPO_RAW/$1" 2>/dev/null; }
repo_cat() { curl -fs --proxy "$PROXY" --max-time 15 "$REPO_RAW/$1" 2>/dev/null || curl -fs --max-time 15 "$REPO_RAW/$1" 2>/dev/null; }

# ── server helpers (mirror init.d) ──
server_list() { uci show "$CONF" 2>/dev/null | sed -n "s/^$CONF\.\([^.=]*\)=server$/\1/p"; }
active_server() {
	local a; a=$(uci -q get $CONF.settings.active_server)
	if [ -n "$a" ] && [ "$(uci -q get $CONF.$a)" = "server" ]; then echo "$a"; return; fi
	server_list | head -1
}
srv_get() { uci -q get "$CONF.$1.$2"; }
group_list() { uci show "$CONF" 2>/dev/null | sed -n "s/^$CONF\.\([^.=]*\)=group$/\1/p"; }
grp_get() { uci -q get "$CONF.$1.$2"; }

usage() {
	cat <<EOF
mierukop — policy routing over mieru (podkop-style)

Usage: mierukop <command>
  start | stop | restart     manage the service
  version                    show module version
  update-check               check github for a newer version
  self-update                download + install the latest version (via tunnel)
  status                     show service + tunnel health
  test                       check tunnel exit IP + a proxied domain
  ping                       latency to server + through the tunnel
  pingall                    ICMP ping (ms) to every server (pick the best)
  speedtest                  measure tunnel throughput (down/up)
  stats                      instantaneous tunnel rx/tx counters + rate
  history                    traffic samples for the dashboard chart
  update                     re-download all lists (via the tunnel) + apply
  lists                      show available community lists
  list add|del <name>        enable/disable a community list
  list show                  show enabled community lists
  server list                show configured servers (* = active)
  server add <label> <ip> <port> <user> <pass> [TCP|UDP]
  server del <name>          remove a server
  server use <name>          switch the active server
  sub <clash-url>            import all mieru servers from a Clash subscription
                             (one login -> mieru fails over between them natively)
  group list                 show routing groups (list -> specific server tunnel)
  group add <name> <server> <list>...   route given lists via a specific server
  group del <name>           remove a routing group
  group server <name> <srv>...          set which server(s) a group uses
  set-server <ip> <port> <user> <pass>   update the active server endpoint
  add-domain <domain>        route a single domain through the tunnel
  add-subnet <cidr>          route a subnet through the tunnel
  count                      how many subnets are loaded
EOF
}

case "$1" in
	start|stop|restart) /etc/init.d/mierukop "$1" ;;
	status)
		sv=$(active_server)
		echo "version: $VERSION"
		echo "service: $(/etc/init.d/mierukop running >/dev/null 2>&1 && echo running || echo stopped)"
		echo "mieru:   $(pgrep -f '/usr/bin/mieru' >/dev/null && echo up || echo down)"
		echo "tun2socks: $(pgrep -f hev-socks5-tunnel >/dev/null && echo up || echo down)"
		echo "tun dev: $(ip -br addr show "$TUN" 2>/dev/null || echo absent)"
		echo "server:  $(srv_get "$sv" label) ($(srv_get "$sv" address):$(srv_get "$sv" port))"
		echo "servers: $(server_list | wc -w)"
		echo "subnets: $(nft list set $NFT_TABLE $NFT_SET 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' | wc -l)"
		;;
	test)
		echo -n "tunnel exit IP: "
		curl -fs --max-time 12 --proxy "$PROXY" https://api.ipify.org 2>/dev/null || echo "FAIL"
		echo
		echo -n "telegram via tunnel: "
		curl -fs --max-time 12 --proxy "$PROXY" -o /dev/null -w "HTTP %{http_code}\n" https://core.telegram.org/ 2>/dev/null || echo "FAIL"
		;;
	ping)
		sv=$(active_server); host=$(srv_get "$sv" address)
		echo -n "server_rtt_ms: "
		ping -c 3 -W 2 "$host" 2>/dev/null | awk -F'= ' '/min\/avg\/max/{split($2,a,"/"); printf "%.1f\n", a[2]; f=1} END{if(!f)print "n/a"}'
		echo -n "tunnel_rtt_ms: "
		t=$(curl -fs --proxy "$PROXY" --max-time 10 -o /dev/null -w '%{time_starttransfer}' https://www.google.com/generate_204 2>/dev/null)
		[ -n "$t" ] && [ "$t" != "0.000000" ] && awk "BEGIN{printf \"%.0f\n\", $t*1000}" || echo "n/a"
		;;
	pingall)
		# ICMP RTT to EVERY server so the user can pick the best one. Also caches the
		# result so the LuCI server dropdowns can show "· Nms" without re-pinging.
		# Output (one per line):  <section>|<label>|<ip>|<avg_ms or -->|<active?0/1>
		act=$(active_server)
		{ for s in $(server_list); do
			ip=$(srv_get "$s" address); lbl=$(srv_get "$s" label)
			rtt=$(ping -c 3 -W 2 "$ip" 2>/dev/null | awk -F'= ' '/min\/avg\/max/{split($2,a,"/"); printf "%.0f", a[2]}')
			a=0; [ "$s" = "$act" ] && a=1
			echo "$s|${lbl:-$s}|$ip|${rtt:-—}|$a"
		done; } | tee "$STATE_DIR/ping.cache"
		;;
	pingcache)
		cat "$STATE_DIR/ping.cache" 2>/dev/null || true ;;
	clients)
		# LAN devices + their connections, and how many are routed through a tunnel
		# (conntrack mark != 0). Output: ip|host|conns|routed|bytes
		LAN=$(ip -4 -o addr show br-lan 2>/dev/null | awk "{print \$4}" | head -1)
		pfx=$(echo "$LAN" | cut -d/ -f1 | cut -d. -f1-3); selfip=$(echo "$LAN" | cut -d/ -f1)
		awk -v pfx="$pfx." -v selfip="$selfip" '
		  { src=""; mk=0; b=0;
		    for(i=1;i<=NF;i++){ if($i~/^src=/&&src==""){src=substr($i,5)} if($i~/^mark=/){mk=substr($i,6)} if($i~/^bytes=/){b+=substr($i,7)} }
		    if(index(src,pfx)==1 && src!=selfip){ c[src]++; by[src]+=b; if(mk!=0&&mk!="")r[src]++ } }
		  END{ for(s in c) print s"|"c[s]"|"(r[s]+0)"|"by[s] }' /proc/net/nf_conntrack 2>/dev/null | sort -t'|' -k3 -rn | while IFS='|' read ip conns routed bytes; do
			host=$(awk -v ip="$ip" "\$3==ip{print \$4}" /tmp/dhcp.leases 2>/dev/null | head -1)
			[ -n "$host" ] && [ "$host" != "*" ] || host="?"
			echo "$ip|$host|$conns|$routed|$bytes"
		done
		;;
	best-server)
		[ -s "$STATE_DIR/ping.cache" ] || /usr/bin/mierukop pingall >/dev/null 2>&1
		best=$(awk -F'|' '$4 ~ /^[0-9]+$/{print $4"|"$1}' "$STATE_DIR/ping.cache" 2>/dev/null | sort -n | head -1)
		bs=$(echo "$best" | cut -d'|' -f2); bms=$(echo "$best" | cut -d'|' -f1)
		[ -n "$bs" ] || { echo "no live server"; exit 1; }
		cur=$(active_server)
		if [ "$bs" != "$cur" ]; then
			uci set $CONF.settings.active_server="$bs"; uci commit $CONF
			echo "switched: $(srv_get "$bs" label) (${bms}ms)"
			/etc/init.d/mierukop restart >/dev/null 2>&1
		else echo "already best: $(srv_get "$bs" label) (${bms}ms)"; fi
		;;
	auto-best)
		[ "$(uci -q get $CONF.settings.auto_best)" = "1" ] || exit 0
		/usr/bin/mierukop pingall >/dev/null 2>&1
		/usr/bin/mierukop best-server >/dev/null 2>&1
		;;
	sub-refresh)
		[ "$(uci -q get $CONF.settings.sub_auto)" = "1" ] || exit 0
		u=$(uci -q get $CONF.settings.sub_url); [ -n "$u" ] || exit 0
		logger -t mierukop "auto sub-refresh"
		/usr/bin/mierukop sub "$u" >/dev/null 2>&1 && { /etc/init.d/mierukop restart >/dev/null 2>&1; /etc/mierukop/update-lists.sh apply >/dev/null 2>&1; }
		;;
	tunnels)
		# per-tunnel live status: name|servers|socks|exit
		base=$(uci -q get $CONF.settings.socks_port || echo 1180)
		ex=$(curl -fs --socks5-hostname 127.0.0.1:$base --max-time 8 https://api.ipify.org 2>/dev/null)
		echo "default|$(srv_get "$(active_server)" label)|$base|${ex:-—}"
		i=0; for g in $(group_list); do [ "$(grp_get "$g" enabled)" = "0" ] && continue; i=$((i+1)); sp=$((base+i))
			srvs=""; for s in $(grp_get "$g" server); do srvs="$srvs $(srv_get "$s" label)"; done
			ex=$(curl -fs --socks5-hostname 127.0.0.1:$sp --max-time 8 https://api.ipify.org 2>/dev/null)
			echo "$(grp_get "$g" label) [$(grp_get "$g" community_lists)]|${srvs# }|$sp|${ex:-—}"
		done
		;;
	selfcheck)
		# per-tunnel: name|exit|country|youtube|telegram|discord
		base=$(uci -q get $CONF.settings.socks_port || echo 1180)
		chk() { n="$1"; sp="$2"
			ex=$(curl -fs --socks5-hostname 127.0.0.1:$sp --max-time 10 https://api.ipify.org 2>/dev/null)
			[ -z "$ex" ] && { echo "$n|—|—|—|—|—"; return; }
			cc=$(curl -fs --max-time 6 https://ipinfo.io/$ex/country 2>/dev/null | tr -d "\n\r ")
			yt=$(curl -fs --socks5-hostname 127.0.0.1:$sp --max-time 12 -o /dev/null -w "%{http_code}" https://www.youtube.com/ 2>/dev/null)
			tg=$(curl -fs --socks5-hostname 127.0.0.1:$sp --max-time 12 -o /dev/null -w "%{http_code}" https://core.telegram.org/ 2>/dev/null)
			dc=$(curl -fs --socks5-hostname 127.0.0.1:$sp --max-time 12 -o /dev/null -w "%{http_code}" https://discord.com/ 2>/dev/null)
			echo "$n|$ex|${cc:-?}|${yt:-000}|${tg:-000}|${dc:-000}"
		}
		chk "default" "$base"
		i=0; for g in $(group_list); do [ "$(grp_get "$g" enabled)" = "0" ] && continue; i=$((i+1)); chk "$(grp_get "$g" label)" "$((base+i))"; done
		;;
	ping-history) [ -f "$STATE_DIR/ping.csv" ] && cat "$STATE_DIR/ping.csv" || true ;;
	version) echo "$VERSION" ;;
	update-check)
		remote=$(repo_cat VERSION | tr -d ' \r\n\t')
		echo "current: $VERSION"
		echo "latest: ${remote:-unknown}"
		if [ -z "$remote" ]; then echo "status: cannot reach github (tunnel down?)"
		elif [ "$remote" = "$VERSION" ]; then echo "status: up-to-date"
		else echo "status: update-available"; fi
		;;
	self-update)
		echo "fetching latest meowMieru from github (via tunnel)…"
		d=/tmp/mkup; rm -rf "$d"; mkdir -p "$d"; ok=1
		# (file repo-path : local)
		for pair in \
			"files/etc/init.d/mierukop:initd" \
			"files/etc/mierukop/update-lists.sh:ul" \
			"files/etc/mierukop/watchdog.sh:wd" \
			"files/usr/bin/mierukop:cli" \
			"luci/htdocs/luci-static/resources/mierukop/lib.js:lib" \
			"luci/htdocs/luci-static/resources/view/mierukop/overview.js:v_overview" \
			"luci/htdocs/luci-static/resources/view/mierukop/servers.js:v_servers" \
			"luci/htdocs/luci-static/resources/view/mierukop/routing.js:v_routing" \
			"luci/htdocs/luci-static/resources/view/mierukop/diagnostics.js:v_diagnostics" \
			"luci/htdocs/luci-static/resources/view/mierukop/settings.js:v_settings" \
			"luci/root/usr/share/luci/menu.d/luci-app-mierukop.json:menu" \
			"luci/root/usr/share/rpcd/acl.d/luci-app-mierukop.json:acl" \
			"VERSION:ver"; do
			repo_dl "${pair%%:*}" "$d/${pair##*:}" && [ -s "$d/${pair##*:}" ] || { echo "  download failed: ${pair%%:*}"; ok=0; }
		done
		# sanity: shell scripts must parse, lib must look like our module
		for f in initd ul wd cli; do sh -n "$d/$f" 2>/dev/null || { echo "  bad script: $f"; ok=0; }; done
		grep -q "loadTunnels" "$d/lib" 2>/dev/null || ok=0
		for v in v_overview v_servers v_routing v_diagnostics v_settings; do grep -q "view.extend" "$d/$v" 2>/dev/null || ok=0; done
		[ "$ok" = 1 ] || { echo "update aborted (download/sanity failed) — current $VERSION kept"; rm -rf "$d"; exit 1; }
		cp "$d/initd" /etc/init.d/mierukop; cp "$d/ul" /etc/mierukop/update-lists.sh
		cp "$d/wd" /etc/mierukop/watchdog.sh; cp "$d/cli" /usr/bin/mierukop
		mkdir -p /www/luci-static/resources/mierukop /www/luci-static/resources/view/mierukop
		cp "$d/lib" /www/luci-static/resources/mierukop/lib.js
		for v in overview servers routing diagnostics settings; do cp "$d/v_$v" "/www/luci-static/resources/view/mierukop/$v.js"; done
		rm -f /www/luci-static/resources/view/mierukop/main.js
		cp "$d/menu" /usr/share/luci/menu.d/luci-app-mierukop.json
		cp "$d/acl" /usr/share/rpcd/acl.d/luci-app-mierukop.json
		mkdir -p /etc/mierukop; cp "$d/ver" "$VER_FILE"
		chmod +x /etc/init.d/mierukop /usr/bin/mierukop /etc/mierukop/*.sh
		sed -i "s/^Version: .*/Version: $(cat "$VER_FILE")/" /usr/lib/opkg/info/mierukop.control 2>/dev/null
		rm -f /tmp/luci-indexcache* /tmp/luci-modulecache/* 2>/dev/null; /etc/init.d/rpcd reload >/dev/null 2>&1
		/etc/init.d/mierukop restart >/dev/null 2>&1
		rm -rf "$d"
		echo "updated to $(cat "$VER_FILE")"
		;;
	update-auto)
		# cron: self-update only if enabled AND a newer version exists
		[ "$(uci -q get $CONF.settings.auto_update)" = "1" ] || exit 0
		remote=$(repo_cat VERSION | tr -d ' \r\n\t')
		[ -n "$remote" ] && [ "$remote" != "$VERSION" ] || exit 0
		logger -t mierukop "auto-update $VERSION -> $remote"
		/usr/bin/mierukop self-update >/dev/null 2>&1
		;;
	speedtest)
		# Cloudflare's speed endpoint refuses mieru/datacenter IPs (returns 0) — use
		# Google's CDN which is reliably reachable through the tunnel. Try a couple of
		# mirrors so a single dead URL doesn't read as "0".
		spd=""; sz=0
		for u in \
			"https://dl.google.com/dl/android/studio/install/2021.1.1.21/android-studio-2021.1.1.21-cros.deb" \
			"https://dl.google.com/go/go1.21.0.linux-amd64.tar.gz" \
			"https://speed.cloudflare.com/__down?bytes=20000000"; do
			res=$(curl -fs --proxy "$PROXY" --max-time 15 -o /dev/null -w '%{speed_download} %{size_download}' --range 0-20000000 "$u" 2>/dev/null)
			spd=$(echo "$res" | awk '{print $1}'); sz=$(echo "$res" | awk '{print $2}')
			[ -n "$spd" ] && [ "${sz:-0}" -gt 1000000 ] && break
		done
		if [ -n "$spd" ] && [ "${sz:-0}" -gt 1000000 ]; then
			awk "BEGIN{printf \"down_mbps: %.1f\n\", $spd*8/1000000}"
		else
			echo "down_mbps: 0"; echo "note: download failed (tunnel down?)"
		fi
		# upload measured against Google's generate_204 collector is unreliable; keep
		# Cloudflare __up but treat 0 as "n/a" rather than a real reading
		tmp="$STATE_DIR/up.bin"; head -c 8000000 /dev/zero > "$tmp" 2>/dev/null
		up=$(curl -fs --proxy "$PROXY" --max-time 10 -o /dev/null \
			-w '%{speed_upload}' --data-binary @"$tmp" \
			"https://speed.cloudflare.com/__up" 2>/dev/null)
		rm -f "$tmp"
		if [ -n "$up" ] && awk "BEGIN{exit !($up>10000)}"; then
			awk "BEGIN{printf \"up_mbps: %.1f\n\", $up*8/1000000}"
		else echo "up_mbps: n/a"; fi
		;;
	stats)
		rx=$(cat /sys/class/net/$TUN/statistics/rx_bytes 2>/dev/null || echo 0)
		tx=$(cat /sys/class/net/$TUN/statistics/tx_bytes 2>/dev/null || echo 0)
		now=$(date +%s); pf="$STATE_DIR/stats.prev"; pt=0; prx=0; ptx=0
		[ -f "$pf" ] && read pt prx ptx < "$pf"
		echo "$now $rx $tx" > "$pf"
		dt=$((now-pt)); [ "$dt" -lt 1 ] && dt=1
		rrate=0; trate=0
		if [ "$pt" -gt 0 ] && [ "$rx" -ge "$prx" ]; then rrate=$(((rx-prx)/dt)); trate=$(((tx-ptx)/dt)); fi
		echo "rx_bytes: $rx"; echo "tx_bytes: $tx"
		echo "rx_rate: $rrate"; echo "tx_rate: $trate"
		;;
	sample)
		# called by cron every minute — append rx/tx rate to a ring buffer
		rx=$(cat /sys/class/net/$TUN/statistics/rx_bytes 2>/dev/null || echo 0)
		tx=$(cat /sys/class/net/$TUN/statistics/tx_bytes 2>/dev/null || echo 0)
		now=$(date +%s); pf="$STATE_DIR/sample.prev"; pt=0; prx=0; ptx=0
		[ -f "$pf" ] && read pt prx ptx < "$pf"
		echo "$now $rx $tx" > "$pf"
		[ "$pt" -gt 0 ] || exit 0
		dt=$((now-pt)); [ "$dt" -lt 1 ] && dt=1
		[ "$rx" -ge "$prx" ] || { prx=$rx; ptx=$tx; }
		echo "$now,$(((rx-prx)/dt)),$(((tx-ptx)/dt))" >> "$TRAFFIC_LOG"
		tail -n 180 "$TRAFFIC_LOG" > "$TRAFFIC_LOG.tmp" 2>/dev/null && mv "$TRAFFIC_LOG.tmp" "$TRAFFIC_LOG"
		# also record the active server's latency (from the ping cache) as a trend
		pm=$(awk -F'|' '$5==1 && $4 ~ /^[0-9]+$/{print $4; exit}' "$STATE_DIR/ping.cache" 2>/dev/null)
		if [ -n "$pm" ]; then
			echo "$now,$pm" >> "$STATE_DIR/ping.csv"
			tail -n 180 "$STATE_DIR/ping.csv" > "$STATE_DIR/ping.csv.tmp" 2>/dev/null && mv "$STATE_DIR/ping.csv.tmp" "$STATE_DIR/ping.csv"
		fi
		;;
	history) [ -f "$TRAFFIC_LOG" ] && cat "$TRAFFIC_LOG" || true ;;
	update) echo "downloading lists via tunnel…"; /etc/mierukop/update-lists.sh download; echo "done. $(/usr/bin/mierukop count) subnets in set" ;;
	lists)  echo "available:"; /etc/mierukop/update-lists.sh available | tr " " "\n" | sed "/^$/d;s/^/  /" ;;
	list)
		case "$2" in
			show) echo "enabled: $(uci -q get $CONF.settings.community_lists)" ;;
			add)
				[ -n "$3" ] || { echo "usage: mierukop list add <name>"; exit 1; }
				cur=" $(uci -q get $CONF.settings.community_lists) "
				case "$cur" in *" $3 "*) echo "$3 already enabled"; exit 0;; esac
				uci set $CONF.settings.community_lists="$(echo $cur $3)"; uci commit $CONF
				echo "enabled $3; run: mierukop update" ;;
			del)
				[ -n "$3" ] || { echo "usage: mierukop list del <name>"; exit 1; }
				new=$(uci -q get $CONF.settings.community_lists | tr " " "\n" | grep -vx "$3" | tr "\n" " ")
				uci set $CONF.settings.community_lists="$new"; uci commit $CONF
				echo "disabled $3; run: mierukop restart" ;;
			*) echo "usage: mierukop list [show|add <name>|del <name>]" ;;
		esac ;;
	server)
		case "$2" in
			list|"")
				act=$(active_server)
				for s in $(server_list); do
					mark=" "; [ "$s" = "$act" ] && mark="*"
					echo "$mark $s | $(srv_get "$s" label) | $(srv_get "$s" address):$(srv_get "$s" port) | $(srv_get "$s" transport)"
				done ;;
			add)
				[ $# -ge 7 ] || { echo "usage: mierukop server add <label> <ip> <port> <user> <pass> [TCP|UDP]"; exit 1; }
				id="srv$(date +%s)"
				uci set $CONF.$id=server
				uci set $CONF.$id.label="$3"; uci set $CONF.$id.address="$4"; uci set $CONF.$id.port="$5"
				uci set $CONF.$id.username="$6"; uci set $CONF.$id.password="$7"; uci set $CONF.$id.transport="${8:-TCP}"
				uci commit $CONF
				echo "added server $id ($3)" ;;
			del)
				[ -n "$3" ] || { echo "usage: mierukop server del <name>"; exit 1; }
				uci -q delete $CONF.$3; uci commit $CONF; echo "deleted $3" ;;
			use)
				[ -n "$3" ] || { echo "usage: mierukop server use <name>"; exit 1; }
				[ "$(uci -q get $CONF.$3)" = "server" ] || { echo "no such server: $3"; exit 1; }
				uci set $CONF.settings.active_server="$3"; uci commit $CONF
				echo "active server -> $3; run: mierukop restart" ;;
			*) echo "usage: mierukop server [list|add|del <name>|use <name>]" ;;
		esac ;;
	group)
		# route a specific list through a specific server via its own tunnel
		case "$2" in
			list|"")
				for g in $(uci show $CONF 2>/dev/null | sed -n "s/^$CONF\.\([^.=]*\)=group$/\1/p"); do
					st=on; [ "$(uci -q get $CONF.$g.enabled)" = "0" ] && st=off
					srvs=""; for s in $(uci -q get $CONF.$g.server); do srvs="$srvs $(srv_get "$s" label)"; done
					echo "  $g [$st] | $(uci -q get $CONF.$g.label) | via:${srvs:- (нет)} | lists: $(uci -q get $CONF.$g.community_lists)"
				done
				[ -z "$(uci show $CONF 2>/dev/null | grep -c '=group')" ] && echo "  (групп нет)" ;;
			add)
				# mierukop group add <name> <server-section[ server2]> <list> [list2...]
				[ $# -ge 5 ] || { echo "usage: mierukop group add <name> <server-section> <list> [list2...]"; echo "  серверы: mierukop server list"; exit 1; }
				gn="g$(echo "$3" | tr -cd 'a-zA-Z0-9')"
				sv="$4"; [ "$(uci -q get $CONF.$sv)" = "server" ] || {
					# try to resolve by label substring
					for s in $(server_list); do case "$(srv_get "$s" label)" in *"$4"*) sv="$s"; break;; esac; done; }
				[ "$(uci -q get $CONF.$sv)" = "server" ] || { echo "no such server: $4 (mierukop server list)"; exit 1; }
				uci set $CONF.$gn=group; uci set $CONF.$gn.enabled=1
				uci set $CONF.$gn.label="$3"; uci -q delete $CONF.$gn.server; uci add_list $CONF.$gn.server="$sv"
				shift 4; uci set $CONF.$gn.community_lists="$*"
				uci commit $CONF
				echo "group $gn: lists [$*] via $(srv_get "$sv" label); run: mierukop restart && mierukop update" ;;
			del)
				[ -n "$3" ] || { echo "usage: mierukop group del <name>"; exit 1; }
				uci -q delete $CONF.$3; uci commit $CONF; echo "deleted $3; run: mierukop restart" ;;
			server)
				# mierukop group server <name> <server-section[ server2 ...]>  (set the group's servers)
				[ -n "$3" ] && [ -n "$4" ] || { echo "usage: mierukop group server <name> <server-section...>"; exit 1; }
				gn="$3"; shift 3; uci -q delete $CONF.$gn.server; for s in $*; do uci add_list $CONF.$gn.server="$s"; done; uci commit $CONF
				echo "group $gn -> servers: $*; run: mierukop restart" ;;
			*) echo "usage: mierukop group [list|add <name> <server> <lists...>|del <name>|server <name> <servers...>]" ;;
		esac ;;
	sub)
		# import mieru servers from a Clash-format subscription (meownet etc.)
		url="$2"; [ -n "$url" ] || { echo "usage: mierukop sub <clash-subscription-url>"; exit 1; }
		tmp="$STATE_DIR/sub.yaml"; tsv="$STATE_DIR/sub.tsv"
		echo "fetching subscription…"
		curl -fsSL --max-time 30 "$url" -o "$tmp" 2>/dev/null || { echo "download failed"; exit 1; }
		# parse each `type: mieru` proxy block -> TSV (name server port transport user pass mux)
		awk '
		  /^[[:space:]]*-[[:space:]]*name:/ {
		    if(t=="mieru"&&s!="") print n"\t"s"\t"p"\t"tr"\t"u"\t"pw"\t"mx;
		    n=$0; sub(/^[[:space:]]*-[[:space:]]*name:[[:space:]]*/,"",n); gsub(/"/,"",n);
		    t="";s="";p="";tr="TCP";u="";pw="";mx="MULTIPLEXING_MIDDLE"; next }
		  /^[[:space:]]*type:/        {v=$0;sub(/^[^:]*:[[:space:]]*/,"",v);gsub(/"/,"",v);t=v}
		  /^[[:space:]]*server:/      {v=$0;sub(/^[^:]*:[[:space:]]*/,"",v);gsub(/"/,"",v);s=v}
		  /^[[:space:]]*port:/        {v=$0;sub(/^[^:]*:[[:space:]]*/,"",v);gsub(/"/,"",v);p=v}
		  /^[[:space:]]*transport:/   {v=$0;sub(/^[^:]*:[[:space:]]*/,"",v);gsub(/"/,"",v);tr=v}
		  /^[[:space:]]*username:/    {v=$0;sub(/^[^:]*:[[:space:]]*/,"",v);gsub(/"/,"",v);u=v}
		  /^[[:space:]]*password:/    {v=$0;sub(/^[^:]*:[[:space:]]*/,"",v);gsub(/"/,"",v);pw=v}
		  /^[[:space:]]*multiplexing:/{v=$0;sub(/^[^:]*:[[:space:]]*/,"",v);gsub(/"/,"",v);mx=v}
		  END { if(t=="mieru"&&s!="") print n"\t"s"\t"p"\t"tr"\t"u"\t"pw"\t"mx }
		' "$tmp" > "$tsv"
		cnt=$(grep -c . "$tsv" 2>/dev/null)
		[ "${cnt:-0}" -gt 0 ] || { echo "no mieru servers found in subscription"; rm -f "$tmp" "$tsv"; exit 1; }
		# drop existing server sections, import fresh
		for s in $(server_list); do uci -q delete $CONF.$s; done
		TAB=$(printf '\t'); first=""; muxset=""
		while IFS="$TAB" read name srv port tr user pass mux; do
			[ -n "$srv" ] || continue
			id="srv$(echo "$srv" | tr -cd '0-9')"
			uci set $CONF.$id=server
			uci set $CONF.$id.label="$name"
			uci set $CONF.$id.address="$srv"
			uci set $CONF.$id.port="$port"
			uci set $CONF.$id.transport="${tr:-TCP}"
			uci set $CONF.$id.username="$user"
			uci set $CONF.$id.password="$pass"
			[ -z "$first" ] && first="$id"
			[ -z "$muxset" ] && muxset="$mux"
		done < "$tsv"
		[ -n "$first" ] && uci set $CONF.settings.active_server="$first"
		[ -n "$muxset" ] && uci set $CONF.settings.multiplexing="$muxset"
		uci set $CONF.settings.sub_url="$url"   # remember subscription for auto-refresh
		uci commit $CONF
		rm -f "$tmp" "$tsv"
		echo "imported $cnt mieru server(s); mux=$muxset; active=$first"
		echo "all share one login -> mieru fails over between them natively."
		echo "run: mierukop restart"
		;;
	set-server)
		[ $# -eq 5 ] || { echo "usage: mierukop set-server <ip> <port> <user> <pass>"; exit 1; }
		sv=$(active_server)
		[ -n "$sv" ] || { sv=main; uci set $CONF.$sv=server; uci set $CONF.settings.active_server=$sv; uci set $CONF.$sv.label="Server 1"; uci set $CONF.$sv.transport=TCP; }
		uci set $CONF.$sv.address="$2"; uci set $CONF.$sv.port="$3"
		uci set $CONF.$sv.username="$4"; uci set $CONF.$sv.password="$5"
		uci commit $CONF
		echo "saved to server '$sv'; run: mierukop restart"
		;;
	count) nft list set $NFT_TABLE $NFT_SET 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/[0-9]+' | wc -l ;;
	add-domain)
		[ -n "$2" ] || { echo "usage: mierukop add-domain <domain>"; exit 1; }
		uci add_list $CONF.user.domain="$2"; uci commit $CONF
		echo "added domain $2; run: mierukop restart"
		;;
	add-subnet)
		[ -n "$2" ] || { echo "usage: mierukop add-subnet <cidr>"; exit 1; }
		uci add_list $CONF.user.subnet="$2"; uci commit $CONF
		nft add element $NFT_TABLE $NFT_SET "{ $2 }" 2>/dev/null
		echo "added subnet $2"
		;;
	*) usage ;;
esac
