config mierukop 'settings'
	option enabled '1'
	# which `config server` section is currently live
	option active_server 'main'
	# automatically switch to the next server if the active one fails
	option failover '1'
	# auto-update the module from github (checked weekly via cron)
	option auto_update '0'
	# auto-pick the lowest-latency server (re-checked every 15 min via cron)
	option auto_best '0'
	# subscription URL (saved on import) + auto re-fetch it daily to rotate blocked IPs
	option sub_url ''
	option sub_auto '0'
	# local socks5 that mieru exposes
	option socks_port '1180'
	# mieru multiplexing level: MULTIPLEXING_OFF|LOW|MIDDLE|HIGH (provider-dependent;
	# meownet subscriptions use LOW). All servers sharing one login fail over natively.
	option multiplexing 'MULTIPLEXING_MIDDLE'
	# tun device + routing table/mark
	option tun_name 'mtun0'
	option tun_addr '198.18.0.1'
	option fwmark '0x1042'
	option route_table '1042'
	# how often to refresh subnet/domain lists (hours; 0 = never)
	option update_interval '24'
	# watchdog: restart the tunnel automatically if it stops passing traffic
	option watchdog '1'
	# kill-switch: drop routed traffic if the tunnel is down (no direct leak)
	option killswitch '0'
	# DNS hijack: force LAN clients to use the router's resolver (so domain-based
	# routing works even if a device is set to its own DNS). Also blocks DoT (853).
	# Devices using DoH (443) must disable encrypted DNS manually.
	option dns_hijack '1'
	# real DNS used to resolve routed domains (reached THROUGH the tunnel)
	option routed_dns '8.8.8.8'
	# community lists from itdoginfo/allow-domains (space-separated). Run:
	#   mierukop lists          — show all available
	#   mierukop list add NAME  — enable one
	# subnet+domain: telegram meta twitter discord roblox
	# subnet only:   cloudflare hetzner digitalocean
	# domain only:   youtube tiktok google_ai google_play hdrezka
	#                russia_outside anime news porn geoblock block
	option community_lists 'telegram youtube discord meta twitter'

# mieru servers. Add more sections for auto-failover; `active_server` above picks
# the live one. Configure via:  mierukop server add <label> <ip> <port> <user> <pass>
config server 'main'
	option label 'Server 1'
	option address '0.0.0.0'
	option port '30443'
	option username 'CHANGE_ME'
	option password 'CHANGE_ME'
	option transport 'TCP'

# Routing groups: send specific lists through a SPECIFIC server via their own tunnel
# (separate mtunN/fwmark/table/set). Everything not in a group uses the default
# tunnel above. Manage via:  mierukop group add <name> <server-section> <lists...>
#config group 'gYouTube'
