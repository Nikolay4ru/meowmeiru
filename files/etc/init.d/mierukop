#!/bin/sh /etc/rc.common
# mierukop — policy routing over a mieru SOCKS5 transport (podkop-style, for mieru)
# Routes selected subnets/domains through mieru via tun2socks (hev-socks5-tunnel) + nftables fwmark.

START=90
STOP=10
USE_PROCD=1

CONF="mierukop"
NFT_TABLE="inet mierukop"
NFT_SET="mierukop_subnets"
RUN_DIR="/var/run/mierukop"
MIERU_CONF="$RUN_DIR/mieru.json"
HEV_CONF="$RUN_DIR/hev.yml"
DNSMASQ_CONF="/tmp/dnsmasq.d/mierukop.conf"

log() { logger -t mierukop "$1"; }

uci_get() { uci -q get "$CONF.settings.$1"; }

setup_nft() {
	local set_name="$1" mark="$2" tun
	tun=$(uci_get tun_name)
	# Own table: mark traffic to set members (prerouting = forwarded LAN clients,
	# output = router-local), plus forward-accept + masquerade for the tun so that
	# forwarded client traffic is allowed out mtun0 (fw4 would otherwise drop it).
	nft -f - <<EOF
table $NFT_TABLE {
	set $NFT_SET {
		type ipv4_addr
		flags interval
		auto-merge
	}
	set mierukop_direct {
		type ipv4_addr
		flags interval
		auto-merge
	}
	chain prerouting {
		type filter hook prerouting priority mangle; policy accept;
		ip daddr @mierukop_direct return
		ip daddr @$NFT_SET meta mark set $mark
	}
	chain output {
		type route hook output priority mangle; policy accept;
		ip daddr @mierukop_direct return
		ip daddr @$NFT_SET meta mark set $mark
	}
	chain forward {
		type filter hook forward priority -1; policy accept;
		# clamp MSS so forwarded clients don't black-hole large TLS segments
		# through the tunnel (non-terminal — falls through to accept below)
		oifname "$tun" tcp flags syn tcp option maxseg size set 1360
		iifname "$tun" tcp flags syn tcp option maxseg size set 1360
		oifname "$tun" accept
		iifname "$tun" accept
	}
	chain postrouting {
		type nat hook postrouting priority srcnat; policy accept;
		oifname "$tun" masquerade
	}
}
EOF
	# DNS hijack: force LAN clients onto the router's resolver so routed domains
	# resolve to the SAME IPs we add to the set (clients using their own DNS would
	# otherwise connect to IPs not in the set and bypass the tunnel).
	if [ "$(uci_get dns_hijack)" != "0" ]; then
		local lan; lan=$(uci_get lan_ifname); [ -n "$lan" ] || lan=br-lan
		nft -f - <<EOF2
table $NFT_TABLE {
	chain dns_redirect {
		type nat hook prerouting priority dstnat - 5; policy accept;
		iifname "$lan" ip daddr != $(ip -4 addr show "$lan" 2>/dev/null | awk '/inet /{print $2}' | cut -d/ -f1 | head -1) udp dport 53 redirect to :53
		iifname "$lan" ip daddr != $(ip -4 addr show "$lan" 2>/dev/null | awk '/inet /{print $2}' | cut -d/ -f1 | head -1) tcp dport 53 redirect to :53
		iifname "$lan" tcp dport 853 reject
	}
}
EOF2
	fi
}

teardown_nft() {
	nft delete table $NFT_TABLE 2>/dev/null
}

# fw4 has `policy drop` on the forward hook and runs AFTER our own chain, so an
# `accept` in the mierukop table does NOT stop fw4 from rejecting forwarded LAN
# clients heading into the tun (the tun is in no firewall zone). The fix is to
# put the tun device in the `lan` zone so fw4 itself permits LAN<->tun forwarding.
setup_fw_zone() {
	local tun="$1" z
	z=$(uci show firewall 2>/dev/null | awk -F'[.=]' "/\\.name='lan'\$/{print \$2; exit}")
	[ -n "$z" ] || return 0
	# idempotent: only touch config + reload fw4 if the device isn't there yet
	if ! uci -q get "firewall.$z.device" | tr ' ' '\n' | grep -qx "$tun"; then
		uci add_list "firewall.$z.device=$tun"
		uci commit firewall
		fw4 reload >/dev/null 2>&1 || /etc/init.d/firewall reload >/dev/null 2>&1
	fi
}
teardown_fw_zone() {
	local tun="$1" z
	z=$(uci show firewall 2>/dev/null | awk -F'[.=]' "/\\.name='lan'\$/{print \$2; exit}")
	[ -n "$z" ] || return 0
	if uci -q get "firewall.$z.device" | tr ' ' '\n' | grep -qx "$tun"; then
		uci -q del_list "firewall.$z.device=$tun"
		uci commit firewall
		fw4 reload >/dev/null 2>&1 || /etc/init.d/firewall reload >/dev/null 2>&1
	fi
}

setup_cron() {
	local cron="/etc/crontabs/root" iv
	touch "$cron"
	sed -i '/mierukop\/\(watchdog\|update-lists\)\.sh/d' "$cron"
	[ "$(uci_get watchdog)" = "1" ] && echo "*/5 * * * * /etc/mierukop/watchdog.sh" >> "$cron"
	iv=$(uci_get update_interval)
	[ -n "$iv" ] && [ "$iv" != "0" ] && echo "23 5 */$(( iv/24>0 ? iv/24 : 1 )) * * /etc/mierukop/update-lists.sh download" >> "$cron"
	/etc/init.d/cron enable >/dev/null 2>&1; /etc/init.d/cron restart >/dev/null 2>&1
}

setup_route() {
	local mark="$1" table="$2" tun="$3"
	ip route replace default dev "$tun" table "$table" 2>/dev/null
	ip rule del fwmark "$mark" lookup "$table" 2>/dev/null
	ip rule add fwmark "$mark" lookup "$table" 2>/dev/null
}

teardown_route() {
	local mark="$1" table="$2"
	ip rule del fwmark "$mark" lookup "$table" 2>/dev/null
	ip route flush table "$table" 2>/dev/null
}

write_mieru_conf() {
	local server port proto user pass socks
	server=$(uci_get server); port=$(uci_get port); proto=$(uci_get protocol)
	user=$(uci_get username); pass=$(uci_get password); socks=$(uci_get socks_port)
	mkdir -p "$RUN_DIR"
	cat > "$MIERU_CONF" <<EOF
{
  "profiles": [{
    "profileName": "mierukop",
    "user": { "name": "$user", "password": "$pass" },
    "servers": [{
      "ipAddress": "$server",
      "portBindings": [
        { "port": $port, "protocol": "TCP" },
        { "port": $port, "protocol": "UDP" }
      ]
    }],
    "mtu": 1400,
    "multiplexing": { "level": "MULTIPLEXING_MIDDLE" }
  }],
  "activeProfile": "mierukop",
  "rpcPort": 8965,
  "socks5Port": $socks,
  "socks5ListenLAN": false,
  "loggingLevel": "INFO"
}
EOF
}

write_hev_conf() {
	local tun addr socks mark table
	tun=$(uci_get tun_name); addr=$(uci_get tun_addr); socks=$(uci_get socks_port)
	mark=$(uci_get fwmark); table=$(uci_get route_table)
	mkdir -p "$RUN_DIR"
	# hev creates the tun but does NOT configure it — a post-up script wires up
	# the address, link state, routing table and ip rule (needs ip-full/iproute2).
	cat > "$RUN_DIR/up.sh" <<EOF
#!/bin/sh
TUN="\$1"
ip addr add ${addr}/24 dev "\$TUN" 2>/dev/null
ip link set "\$TUN" up
ip route replace default dev "\$TUN" table $table
ip rule del fwmark $mark lookup $table 2>/dev/null
ip rule add fwmark $mark lookup $table
# loose reverse-path filtering so tunnel replies are not dropped
sysctl -w net.ipv4.conf.all.rp_filter=2 >/dev/null 2>&1
sysctl -w net.ipv4.conf.\$TUN.rp_filter=2 >/dev/null 2>&1
logger -t mierukop "tun \$TUN up: \$(ip -br addr show \$TUN)"
EOF
	chmod +x "$RUN_DIR/up.sh"
	cat > "$HEV_CONF" <<EOF
tunnel:
  name: $tun
  mtu: 8500
  post-up-script: $RUN_DIR/up.sh
socks5:
  address: 127.0.0.1
  port: $socks
  udp: udp
misc:
  task-stack-size: 81920
  log-level: warn
EOF
}

setup_dnsmasq() {
	# Route configured domains through the tunnel: dnsmasq adds resolved IPs to the nft set.
	# SAFETY: the `nftset=` directive requires dnsmasq-full. On plain dnsmasq it would
	# crash the resolver (DNS down for the whole LAN), so we skip it unless supported.
	rm -f "$DNSMASQ_CONF"
	if ! dnsmasq --help 2>&1 | grep -q -- '--nftset'; then
		log "dnsmasq has no nftset support (install dnsmasq-full) — domain routing disabled, subnets still work"
		return 0
	fi
	mkdir -p /tmp/dnsmasq.d
	: > "$DNSMASQ_CONF"
	config_load "$CONF"
	config_list_foreach user domain _emit_domain
	[ -s "$DNSMASQ_CONF" ] && /etc/init.d/dnsmasq restart >/dev/null 2>&1
}
_emit_domain() {
	# nftset syntax for OpenWrt fw4 (nftables): add resolved IPs to our set
	echo "nftset=/$1/4#${NFT_TABLE##* }#${NFT_TABLE%% *}#${NFT_SET}" >> "$DNSMASQ_CONF"
}

start_service() {
	[ "$(uci_get enabled)" = "1" ] || { log "disabled in config"; return 0; }
	local mark table tun
	mark=$(uci_get fwmark); table=$(uci_get route_table); tun=$(uci_get tun_name)

	write_mieru_conf
	write_hev_conf
	setup_nft "$NFT_SET" "$mark"
	setup_fw_zone "$tun"   # let fw4 permit forwarded LAN clients into the tun
	# domain dnsmasq drop-in (community + user domains) is built by update-lists.sh apply below

	# mieru stores its config in its own state dir; apply BEFORE running.
	HOME=/root /usr/bin/mieru apply config "$MIERU_CONF" >/dev/null 2>&1

	# 1) mieru client (socks5 transport)
	procd_open_instance mieru
	procd_set_param command /usr/bin/mieru run
	procd_set_param env HOME=/root
	procd_set_param respawn 3600 5 0
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance

	# 2) tun2socks (hev-socks5-tunnel) → creates tun + (via post-up) wires routing
	procd_open_instance tun2socks
	procd_set_param command /usr/bin/hev-socks5-tunnel "$HEV_CONF"
	procd_set_param respawn 3600 5 0
	procd_close_instance

	# kill-switch: blackhole fallback so routed traffic is dropped (not leaked direct)
	# whenever the tun route is gone. Lower priority than the tun default route.
	if [ "$(uci_get killswitch)" = "1" ]; then
		ip route add blackhole default table "$table" metric 100 2>/dev/null
	fi

	# install/refresh helper cron (watchdog + periodic list refresh)
	setup_cron

	# load subnet lists into the set after services come up
	( sleep 6
	  /etc/mierukop/update-lists.sh apply
	  log "started: routing selected traffic via mieru ($tun, mark $mark)"
	) &
}

stop_service() {
	local mark table
	mark=$(uci_get fwmark); table=$(uci_get route_table)
	teardown_route "$mark" "$table"
	teardown_nft
	teardown_fw_zone "$(uci_get tun_name)"
	ip link del "$(uci_get tun_name)" 2>/dev/null
	rm -f "$DNSMASQ_CONF" /tmp/dnsmasq.d/mierukop-domains.conf /tmp/dnsmasq.*.d/mierukop-domains.conf 2>/dev/null
	sed -i '/mierukop\/\(watchdog\|update-lists\)\.sh/d' /etc/crontabs/root 2>/dev/null
	/etc/init.d/dnsmasq restart >/dev/null 2>&1
	log "stopped"
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger "$CONF"
}
