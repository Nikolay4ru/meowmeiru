#!/bin/sh /etc/rc.common
# mierukop — policy routing over mieru SOCKS5 transports (podkop-style, for mieru)
# Default tunnel routes most lists; optional `config group` sections route specific
# lists through specific server(s) via their own tunnel (mtunN/fwmark/table/nft set).

START=90
STOP=10
USE_PROCD=1

CONF="mierukop"
NFT_TABLE="inet mierukop"
NFT_SET="mierukop_subnets"
RUN_DIR="/var/run/mierukop"

log() { logger -t mierukop "$1"; }
uci_get() { uci -q get "$CONF.settings.$1"; }
srv_get() { uci -q get "$CONF.$1.$2"; }
grp_get() { uci -q get "$CONF.$1.$2"; }

server_list() { uci show "$CONF" 2>/dev/null | sed -n "s/^$CONF\.\([^.=]*\)=server$/\1/p"; }
group_list()  { uci show "$CONF" 2>/dev/null | sed -n "s/^$CONF\.\([^.=]*\)=group$/\1/p"; }

active_server() {
	local a; a=$(uci_get active_server)
	if [ -n "$a" ] && [ "$(uci -q get "$CONF.$a")" = "server" ]; then echo "$a"; return; fi
	local first; first=$(server_list | head -1)
	[ -n "$first" ] && { echo "$first"; return; }
	if [ -n "$(uci -q get "$CONF.settings.server")" ]; then
		uci -q set "$CONF.main=server"; uci -q set "$CONF.main.label=Server 1"
		uci -q set "$CONF.main.address=$(uci -q get $CONF.settings.server)"
		uci -q set "$CONF.main.port=$(uci -q get $CONF.settings.port)"
		uci -q set "$CONF.main.username=$(uci -q get $CONF.settings.username)"
		uci -q set "$CONF.main.password=$(uci -q get $CONF.settings.password)"
		uci -q set "$CONF.main.transport=$(uci -q get $CONF.settings.transport || echo TCP)"
		uci -q set "$CONF.settings.active_server=main"; uci -q commit "$CONF"; echo main
	fi
}
rotate_server() {
	local cur next first
	cur=$(active_server); first=$(server_list | head -1)
	next=$(server_list | awk -v c="$cur" 'f{print;exit} $0==c{f=1}'); [ -n "$next" ] || next="$first"
	[ -n "$next" ] && [ "$next" != "$cur" ] || return 1
	uci -q set "$CONF.settings.active_server=$next"; uci -q commit "$CONF"
	log "failover: $cur -> $next"; echo "$next"
}

# ── tunnel enumeration ───────────────────────────────────────────────────────
# Emits one line per active tunnel:  "<idx>|<kind>|<group-name>"
# idx 0 = default tunnel (settings); idx 1.. = each enabled `config group`.
tunnels() {
	echo "0|default|"
	local i=0 g
	for g in $(group_list); do
		[ "$(grp_get "$g" enabled)" = "0" ] && continue
		i=$((i+1)); echo "$i|group|$g"
	done
}
# Per-index derived params (no collisions): tun/socks/mark/table/rpc/addr.
t_tun()   { echo "mtun$1"; }
t_socks() { echo $(( ${MK_SOCKS_BASE:-1180} + $1 )); }
t_mark()  { printf '0x%x' $(( 0x1042 + $1 )); }
t_table() { echo $(( 1042 + $1 )); }
t_rpc()   { echo $(( 8965 + $1 )); }
t_addr()  { echo "198.18.$1.1"; }
t_set()   { [ "$2" = default ] && echo "$NFT_SET" || echo "mierukop_$3"; }

# Servers (sections) backing a tunnel. Default = all sharing the active login
# (native failover). Group = exactly the server(s) it lists (specific routing).
tunnel_servers() {
	local kind="$1" g="$2" sv user pass s
	if [ "$kind" = default ]; then
		sv=$(active_server); user=$(srv_get "$sv" username); pass=$(srv_get "$sv" password)
		for s in $(server_list); do
			[ "$(srv_get "$s" username)" = "$user" ] && [ "$(srv_get "$s" password)" = "$pass" ] && echo "$s"
		done
	else
		grp_get "$g" server | tr ' ' '\n' | sed '/^$/d'
	fi
}

_bindings() {
	case "$2" in
		TCP) echo "{ \"port\": $1, \"protocol\": \"TCP\" }" ;;
		UDP) echo "{ \"port\": $1, \"protocol\": \"UDP\" }" ;;
		*)   echo "{ \"port\": $1, \"protocol\": \"TCP\" }, { \"port\": $1, \"protocol\": \"UDP\" }" ;;
	esac
}
_servers_json() {  # args: server sections
	local sj="" a p t s
	for s in "$@"; do
		a=$(srv_get "$s" address); p=$(srv_get "$s" port); t=$(srv_get "$s" transport)
		[ -n "$a" ] && [ -n "$p" ] || continue
		[ -n "$sj" ] && sj="$sj,"
		sj="$sj{ \"ipAddress\": \"$a\", \"portBindings\": [ $(_bindings "$p" "$t") ] }"
	done
	echo "$sj"
}

write_mieru_conf_f() {  # file profile rpc socks user pass servers_json
	local f="$1" prof="$2" rpc="$3" socks="$4" user="$5" pass="$6" sj="$7" mux
	mux=$(uci_get multiplexing); [ -n "$mux" ] || mux=MULTIPLEXING_MIDDLE
	mkdir -p "$RUN_DIR"
	cat > "$f" <<EOF
{
  "profiles": [{
    "profileName": "$prof",
    "user": { "name": "$user", "password": "$pass" },
    "servers": [ $sj ],
    "mtu": 1400,
    "multiplexing": { "level": "$mux" }
  }],
  "activeProfile": "$prof",
  "rpcPort": $rpc,
  "socks5Port": $socks,
  "socks5ListenLAN": false,
  "loggingLevel": "INFO"
}
EOF
	chmod 600 "$f" 2>/dev/null
}

write_hev_conf_f() {  # hev_file up_file tun addr socks mark table
	local hev="$1" up="$2" tun="$3" addr="$4" socks="$5" mark="$6" table="$7"
	cat > "$up" <<EOF
#!/bin/sh
TUN="\$1"
ip addr add ${addr}/24 dev "\$TUN" 2>/dev/null
ip link set "\$TUN" up
ip route replace default dev "\$TUN" table $table
ip rule del fwmark $mark lookup $table 2>/dev/null
ip rule add fwmark $mark lookup $table
sysctl -w net.ipv4.conf.all.rp_filter=2 >/dev/null 2>&1
sysctl -w net.ipv4.conf.\$TUN.rp_filter=2 >/dev/null 2>&1
logger -t mierukop "tun \$TUN up (table $table mark $mark)"
EOF
	chmod +x "$up"
	cat > "$hev" <<EOF
tunnel:
  name: $tun
  mtu: 8500
  post-up-script: $up
socks5:
  address: 127.0.0.1
  port: $socks
  udp: udp
misc:
  task-stack-size: 81920
  log-level: warn
EOF
}

# ── nftables: one table, a set + marking rule per tunnel ─────────────────────
setup_nft_all() {
	local sets="" pre="" out="" fwd="" post="" defrule="" line idx kind g tun mark setname
	sets="	set mierukop_direct { type ipv4_addr; flags interval; auto-merge; }"
	for line in $(tunnels); do
		idx=${line%%|*}; kind=$(echo "$line" | cut -d'|' -f2); g=$(echo "$line" | cut -d'|' -f3)
		tun=$(t_tun "$idx"); mark=$(t_mark "$idx"); setname=$(t_set "$idx" "$kind" "$g")
		sets="$sets
	set $setname { type ipv4_addr; flags interval; auto-merge; }"
		fwd="$fwd
		oifname \"$tun\" tcp flags syn tcp option maxseg size set 1360
		iifname \"$tun\" tcp flags syn tcp option maxseg size set 1360
		oifname \"$tun\" accept
		iifname \"$tun\" accept"
		post="$post
		oifname \"$tun\" masquerade"
		if [ "$kind" = default ]; then
			defrule="		ip daddr @$setname meta mark set $mark"
		else
			pre="$pre
		ip daddr @$setname meta mark set $mark"
			out="$out
		ip daddr @$setname meta mark set $mark"
		fi
	done
	nft -f - <<EOF
table $NFT_TABLE {
$sets
	chain prerouting {
		type filter hook prerouting priority mangle; policy accept;
		ip daddr @mierukop_direct return
$pre
$defrule
	}
	chain output {
		type route hook output priority mangle; policy accept;
		ip daddr @mierukop_direct return
$out
$defrule
	}
	chain forward {
		type filter hook forward priority -1; policy accept;
$fwd
	}
	chain postrouting {
		type nat hook postrouting priority srcnat; policy accept;
$post
	}
}
EOF
	if [ "$(uci_get dns_hijack)" != "0" ]; then
		local lan ip; lan=$(uci_get lan_ifname); [ -n "$lan" ] || lan=br-lan
		ip=$(ip -4 addr show "$lan" 2>/dev/null | awk '/inet /{print $2}' | cut -d/ -f1 | head -1)
		nft -f - <<EOF2
table $NFT_TABLE {
	chain dns_redirect {
		type nat hook prerouting priority dstnat - 5; policy accept;
		iifname "$lan" ip daddr != $ip udp dport 53 redirect to :53
		iifname "$lan" ip daddr != $ip tcp dport 53 redirect to :53
		iifname "$lan" tcp dport 853 reject
	}
}
EOF2
	fi
}
teardown_nft() { nft delete table $NFT_TABLE 2>/dev/null; }

setup_fw_zone() {
	local tun="$1" z
	z=$(uci show firewall 2>/dev/null | awk -F'[.=]' "/\\.name='lan'\$/{print \$2; exit}")
	[ -n "$z" ] || return 0
	if ! uci -q get "firewall.$z.device" | tr ' ' '\n' | grep -qx "$tun"; then
		uci add_list "firewall.$z.device=$tun"; uci commit firewall
		fw4 reload >/dev/null 2>&1 || /etc/init.d/firewall reload >/dev/null 2>&1
	fi
}
teardown_fw_zone() {
	local tun="$1" z
	z=$(uci show firewall 2>/dev/null | awk -F'[.=]' "/\\.name='lan'\$/{print \$2; exit}")
	[ -n "$z" ] || return 0
	if uci -q get "firewall.$z.device" | tr ' ' '\n' | grep -qx "$tun"; then
		uci -q del_list "firewall.$z.device=$tun"; uci commit firewall
		fw4 reload >/dev/null 2>&1 || /etc/init.d/firewall reload >/dev/null 2>&1
	fi
}

setup_cron() {
	local cron="/etc/crontabs/root" iv
	touch "$cron"
	sed -i '/mierukop\/\(watchdog\|update-lists\)\.sh/d;/mierukop sample/d;/mierukop pingall/d;/mierukop update-auto/d' "$cron"
	[ "$(uci_get watchdog)" = "1" ] && echo "*/5 * * * * /etc/mierukop/watchdog.sh" >> "$cron"
	echo "* * * * * /usr/bin/mierukop sample" >> "$cron"
	echo "*/10 * * * * /usr/bin/mierukop pingall >/dev/null 2>&1" >> "$cron"
	# weekly self-update check (only updates if auto_update=1 and a newer version exists)
	echo "17 4 * * 6 /usr/bin/mierukop update-auto >/dev/null 2>&1" >> "$cron"
	iv=$(uci_get update_interval)
	[ -n "$iv" ] && [ "$iv" != "0" ] && echo "23 5 */$(( iv/24>0 ? iv/24 : 1 )) * * /etc/mierukop/update-lists.sh download" >> "$cron"
	/etc/init.d/cron enable >/dev/null 2>&1; /etc/init.d/cron restart >/dev/null 2>&1
}

# bring up one tunnel's mieru + hev procd instances (called inside start_service)
bring_up_tunnel() {
	local idx="$1" kind="$2" g="$3"
	local tun socks mark table rpc addr conf hev up home prof mi ti user pass sj first
	tun=$(t_tun "$idx"); socks=$(t_socks "$idx"); mark=$(t_mark "$idx")
	table=$(t_table "$idx"); rpc=$(t_rpc "$idx"); addr=$(t_addr "$idx")
	if [ "$kind" = default ]; then
		conf="$RUN_DIR/mieru.json"; hev="$RUN_DIR/hev.yml"; up="$RUN_DIR/up0.sh"
		home=/root; prof=mierukop; mi=mieru; ti=tun2socks
	else
		conf="$RUN_DIR/mieru-$g.json"; hev="$RUN_DIR/hev-$g.yml"; up="$RUN_DIR/up-$g.sh"
		home="$RUN_DIR/h$idx"; prof="mk_$g"; mi="mieru-$g"; ti="tun2socks-$g"; mkdir -p "$home"
	fi
	first=$(tunnel_servers "$kind" "$g" | head -1)
	[ -n "$first" ] || { log "tunnel $idx ($kind $g): no servers, skip"; return 1; }
	user=$(srv_get "$first" username); pass=$(srv_get "$first" password)
	sj=$(_servers_json $(tunnel_servers "$kind" "$g"))
	write_mieru_conf_f "$conf" "$prof" "$rpc" "$socks" "$user" "$pass" "$sj"
	write_hev_conf_f "$hev" "$up" "$tun" "$addr" "$socks" "$mark" "$table"
	HOME="$home" /usr/bin/mieru apply config "$conf" >/dev/null 2>&1
	procd_open_instance "$mi"
	procd_set_param command /usr/bin/mieru run
	procd_set_param env HOME="$home" GOGC=20 GOMEMLIMIT=48MiB
	procd_set_param respawn 3600 5 0
	procd_close_instance
	procd_open_instance "$ti"
	procd_set_param command /usr/bin/hev-socks5-tunnel "$hev"
	procd_set_param respawn 3600 5 0
	procd_close_instance
	[ "$(uci_get killswitch)" = "1" ] && ip route add blackhole default table "$table" metric 100 2>/dev/null
	log "tunnel up: idx=$idx kind=$kind ${g:+grp=$g }tun=$tun socks=$socks mark=$mark"
}

start_service() {
	[ "$(uci_get enabled)" = "1" ] || { log "disabled in config"; return 0; }
	chmod 600 /etc/config/mierukop 2>/dev/null
	local line idx kind g
	setup_nft_all
	for line in $(tunnels); do
		idx=${line%%|*}; kind=$(echo "$line" | cut -d'|' -f2); g=$(echo "$line" | cut -d'|' -f3)
		setup_fw_zone "$(t_tun "$idx")"
		bring_up_tunnel "$idx" "$kind" "$g"
	done
	setup_cron
	( sleep 6; /etc/mierukop/update-lists.sh apply; log "started: $(tunnels | wc -l) tunnel(s)" ) &
}

stop_service() {
	local line idx kind g
	for line in $(tunnels); do
		idx=${line%%|*}
		ip rule del fwmark "$(t_mark "$idx")" lookup "$(t_table "$idx")" 2>/dev/null
		ip route flush table "$(t_table "$idx")" 2>/dev/null
		teardown_fw_zone "$(t_tun "$idx")"
		ip link del "$(t_tun "$idx")" 2>/dev/null
	done
	teardown_nft
	rm -f /tmp/dnsmasq.d/mierukop*.conf /tmp/dnsmasq.*.d/mierukop*.conf 2>/dev/null
	sed -i '/mierukop\/\(watchdog\|update-lists\)\.sh/d;/mierukop sample/d;/mierukop pingall/d;/mierukop update-auto/d' /etc/crontabs/root 2>/dev/null
	/etc/init.d/dnsmasq restart >/dev/null 2>&1
	log "stopped"
}

reload_service() { stop; start; }
service_triggers() { procd_add_reload_trigger "$CONF"; }
